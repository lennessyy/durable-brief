# LLM provider (Venice AI by default, any OpenAI-compatible endpoint works)
LLM_API_KEY=your-venice-or-openai-api-key
LLM_BASE_URL=https://api.venice.ai/api/v1/chat/completions
LLM_MODEL=llama-3.3-70b

# Telegram delivery
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Google CLI (gog) path — defaults to /usr/local/bin/gog
# GOG_PATH=/usr/local/bin/gog
